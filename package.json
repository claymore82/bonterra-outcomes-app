{
  "name": "bonstart",
  "version": "2.0.0",
  "private": true,
  "description": "⚠️ Run 'npm run bonstart:init' to configure this project",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/next",
    "build": "npm run build -w packages/next",
    "sst:dev": "sst dev",
    "sst:deploy": "sst deploy",
    "lint": "npm run lint -w packages/next",
    "prettier": "npm run prettier -w packages/next",
    "prettier:check": "npm run prettier:check -w packages/next",
    "typecheck": "npm run typecheck -w packages/next",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "bonstart:init": "node scripts/setup.js",
    "postinstall": "node scripts/copy-stitch-docs.mjs",
    "prepare": "node scripts/setup-hooks.js",
    "docs:lint:md": "markdownlint 'docs/**/*.md' --config tooling/.markdownlint.json --rules tooling/lint-rules/",
    "docs:lint:vale": "bash tooling/scripts/run-vale.sh docs/",
    "docs:lint": "npm run docs:lint:md && npm run docs:lint:vale"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "markdownlint-cli": "^0.43.0",
    "sst": "^3.9.28",
    "typescript": "^5.7.2"
  },
  "optionalDependencies": {
    "sst-darwin-arm64": "3.17.19",
    "sst-darwin-x64": "3.17.19",
    "sst-linux-arm64": "3.17.19",
    "sst-linux-x64": "3.17.19",
    "sst-win32-x64": "3.17.19"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1022.0",
    "@highcharts/react": "^4.2.1",
    "highcharts": "^12.5.0",
    "recharts": "^3.8.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
