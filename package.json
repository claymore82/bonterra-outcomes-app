{
  "name": "bonstart-template",
  "version": "2.0.0",
  "private": true,
  "description": "⚠️ Run 'npm run bonstart:init' to configure this project",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/core",
    "build": "npm run build -w packages/core",
    "sst:dev": "npm run sst:dev -w packages/core",
    "sst:deploy": "npm run sst:deploy -w packages/core",
    "lint": "npm run lint -w packages/core",
    "prettier": "npm run prettier -w packages/core",
    "prettier:check": "npm run prettier:check -w packages/core",
    "typecheck": "npm run typecheck -w packages/core",
    "bonstart:init": "node scripts/setup.js",
    "prepare": "node scripts/setup-hooks.js"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "sst": "^3.9.28",
    "typescript": "^5.7.2"
  },
  "optionalDependencies": {
    "sst-darwin-arm64": "3.17.19",
    "sst-darwin-x64": "3.17.19",
    "sst-linux-arm64": "3.17.19",
    "sst-linux-x64": "3.17.19",
    "sst-win32-x64": "3.17.19"
  }
}
