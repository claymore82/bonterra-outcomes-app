#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🚀 Running pre-push checks..."
echo "Checking code quality before push..."

# Run prettier, lint, and typecheck
npm run prettier:check || {
  echo "❌ Prettier check failed. Run 'npm run prettier' to fix formatting."
  exit 1
}

npm run lint || {
  echo "❌ ESLint failed. Fix linting errors before pushing."
  exit 1
}

npm run typecheck || {
  echo "❌ TypeScript check failed. Fix type errors before pushing."
  exit 1
}

echo "✅ Pre-push checks passed!"
